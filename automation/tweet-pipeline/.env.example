# Slack browser-session tokens. Extract from your browser devtools while logged into Slack.
#
# How to get these:
#   1. Open your Slack workspace in a browser.
#   2. Open DevTools → Application → Local Storage → https://app.slack.com → "config" key.
#      The value is JSON; find your team's `token` field starting with `xoxc-...`.
#   3. Open DevTools → Application → Cookies → https://<workspace>.slack.com → `d` cookie.
#      That value (URL-encoded, starting with `xoxd-...`) goes into SLACK_XOXD_COOKIE.
#
# Bot tokens (xoxb-) WILL NOT WORK here — this hits the user-facing search API which
# requires the browser session tokens specifically.

SLACK_XOXC_TOKEN=xoxc-replace-me
SLACK_XOXD_COOKIE=xoxd-replace-me-urlencoded

# The slug from <workspace>.slack.com. For acme.slack.com this is "acme".
SLACK_WORKSPACE_DOMAIN=your-workspace
