<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.vault-lint</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>/Users/derekcedarbaum/.local/bin/claude -p "/vault-lint" &gt; "$HOME/.claude/logs/vault-lint-$(date +%Y-%m-%d).log" 2&gt;&amp;1</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/derekcedarbaum/.claude/logs/vault-lint.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/derekcedarbaum/.claude/logs/vault-lint.err</string>
</dict>
</plist>
